{
  "manifest_version": 3,
  "name": "VocaSpot",
  "version": "0.1.0",
  "description": "Highlights words on news pages based on your CEFR level and shows context-aware definitions.",
  "permissions": [
    "storage",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "https://api.dictionaryapi.dev/*"
  ],
  "background": {
    "service_worker": "service_worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "VocaSpot"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "lib/compromise.min.js",
        "context_extractor.js",
        "tooltip.js",
        "highlighter.js",
        "content_script.js"
      ],
      "css": [
        "styles/vocaspot.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "data/cefr_wordlist.json"
      ],
      "matches": [
        "http://*/*",
        "https://*/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
